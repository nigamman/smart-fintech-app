<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_outer_background"
    android:padding="6dp"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_inner_background"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFE TODAY"
                android:textAllCaps="true"
                android:textColor="#8A8D9F"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/widget_safe_to_spend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1,240"
                android:textColor="#D5B266"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/widget_total_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Cash: ₹0"
                android:textColor="#7F8295"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Bottom Left Remaining Days -->
        <TextView
            android:id="@+id/widget_remaining_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_marginBottom="4dp"
            android:text="15 days left"
            android:textColor="#7F8295"
            android:textSize="11sp"
            android:fontFamily="sans-serif" />

        <!-- Bottom Right Circular Add Button -->
        <TextView
            android:id="@+id/btn_add_custom"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:text="+"
            android:textColor="#18191D"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/widget_circle_button_bg"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>
</RelativeLayout>
