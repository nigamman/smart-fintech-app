<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_outer_background"
    android:padding="6dp"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_inner_background"
        android:padding="16dp">

        <!-- Top Header: Title -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:text="SAFE TO SPEND TODAY"
            android:textAllCaps="true"
            android:textColor="#8A8D9F"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Row with Amount and Plus Button -->
        <RelativeLayout
            android:id="@+id/amount_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_title"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/widget_safe_to_spend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="₹1,240"
                android:textColor="#D5B266"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Circular Plus Button next to amount (aligned right) -->
            <TextView
                android:id="@+id/btn_add_custom"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="+"
                android:textColor="#18191D"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/widget_circle_button_bg"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- Dynamic Category and Coffee Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/amount_row"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_top_cat_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/widget_action_button_bg"
                android:drawableTop="@drawable/ic_diamond_filled"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Food"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_top_cat_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/widget_action_button_bg"
                android:drawableTop="@drawable/ic_diamond_outline"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Travel"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Fixed Coffee Background Log Button -->
            <LinearLayout
                android:id="@+id/btn_coffee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/widget_action_button_bg"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coffee ₹80"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hidden views to retain code compatibility in Kotlin widget updates -->
        <TextView
            android:id="@+id/widget_total_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_remaining_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </RelativeLayout>
</RelativeLayout>
