<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Safe to Spend"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_remaining_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="-- days left"
            android:textColor="#94A3B8"
            android:textSize="11sp" />
    </RelativeLayout>

    <!-- Main Amount Display -->
    <TextView
        android:id="@+id/widget_safe_to_spend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0"
        android:textColor="#10B981"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_total_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Cash: $0"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:weightSum="4">

        <!-- Top Category 1 Button (Dynamic Deep Link) -->
        <Button
            android:id="@+id/btn_top_cat_1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1.1"
            android:text="Category 1"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="@drawable/widget_button_bg"
            android:layout_marginEnd="4dp" />

        <!-- Top Category 2 Button (Dynamic Deep Link) -->
        <Button
            android:id="@+id/btn_top_cat_2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1.1"
            android:text="Category 2"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="@drawable/widget_button_bg"
            android:layout_marginEnd="4dp" />

        <!-- Fixed Coffee Background Log Button -->
        <Button
            android:id="@+id/btn_coffee"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1.1"
            android:text="+☕ $10"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="@drawable/widget_button_bg"
            android:layout_marginEnd="4dp" />

        <!-- Custom Add Button (Deep Link) -->
        <Button
            android:id="@+id/btn_add_custom"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.7"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/widget_custom_button_bg" />
    </LinearLayout>
</LinearLayout>
